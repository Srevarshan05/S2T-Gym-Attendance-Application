# ── Database (Supabase PostgreSQL via asyncpg) ─────────────────────────────
# Format: postgresql+asyncpg://[user]:[password]@[host]:[port]/[db]
DATABASE_URL=postgresql+asyncpg://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres

# ── JWT ────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=change-this-to-a-random-64-char-hex-string-before-going-to-production
JWT_ACCESS_TOKEN_TTL=900
JWT_REFRESH_TOKEN_TTL=7776000

# ── Application ────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
GYM_NAME=S2T Fitness Studio
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,https://s2tfitness.in

# ── Brute-Force Protection ─────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30

# ── Admin Seed Account ─────────────────────────────────────────────────────
ADMIN_EMAIL=admin@s2tfitness.in
ADMIN_PASSWORD=ChangeMe@Production1
